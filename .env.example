# Onboard Platform — Environment Variables
# Copy this file to .env.local and fill in the values

# =============================================================================
# REQUIRED
# =============================================================================

# Neon PostgreSQL connection string
# Get this from https://console.neon.tech
DATABASE_URL=postgresql://user:password@host/database?sslmode=require

# =============================================================================
# OPTIONAL
# =============================================================================

# Public URL of your deployment (for OG images and canonical URLs)
# Default: http://localhost:3000 in development
NEXT_PUBLIC_BASE_URL=https://your-domain.com

# =============================================================================
# INTEGRATIONS (Optional)
# =============================================================================

# Platphorm News Ecosystem
# These are the default values - change if using custom instances
EMOJI_API_URL=https://emoji.platphormnews.com/api
MCP_HUB_URL=https://mcp.platphormnews.com/api
SVG_API_URL=https://svg.platphormnews.com/api
JSON_API_URL=https://json.platphormnews.com/api
XML_API_URL=https://xml.platphormnews.com/api
CALENDAR_API_URL=https://calendar.platphormnews.com/api
KANBAN_API_URL=https://kanban.platphormnews.com/api

# =============================================================================
# LOGGING
# =============================================================================

# Minimum log level (debug, info, warn, error, fatal)
LOG_LEVEL=info

# Enable structured JSON logging
STRUCTURED_LOGS=true

# =============================================================================
# VERCEL (Auto-populated on Vercel)
# =============================================================================

# These are set automatically by Vercel - do not set manually
# VERCEL_URL
# VERCEL_ENV
# VERCEL_REGION
# VERCEL_GIT_COMMIT_SHA
# VERCEL_GIT_COMMIT_REF
# VERCEL_GIT_COMMIT_DATE

# =============================================================================
# DEVELOPMENT
# =============================================================================

# Enable debug logging
DEBUG=false

# Disable SSL for local PostgreSQL
# DATABASE_SSL=false
